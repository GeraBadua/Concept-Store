# Application Mode
# Set to 'true' for demo mode (no database required)
# Set to 'false' to use MySQL database
DEMO_MODE=true

# Database Configuration (only needed if DEMO_MODE=false)
# MYSQL_HOST=localhost
# MYSQL_USER=root
# MYSQL_PASSWORD=your_mysql_password
# MYSQL_PORT=3306
# MYSQL_DATABASE=concept_store

# Cloudinary Configuration (only needed if DEMO_MODE=false for image uploads)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Environment
NODE_ENV=development
